<div class="mb-2">
  <label class="flex cursor-pointer items-center gap-2 text-sm text-gray-700">
    <%= check_box_tag "dedication_toggle", "1", form.object.dedication_message.present?,
          data: { action: "donation-form#toggleDedication" } %>
    רוצה להוסיף הקדשה?
  </label>

  <div class="mt-2" data-donation-form-target="dedicationWrapper" <%= "hidden" unless form.object.dedication_message.present? %>>
    <%= form.text_area :dedication_message, rows: 3, placeholder: "לדוגמה: לזכר...",
          class: "w-full rounded-md border-gray-300 focus:border-orange-500 focus:ring-orange-500" %>
  </div>
</div>
