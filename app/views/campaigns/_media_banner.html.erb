<%# Wide background image with an optional centered "watch the video" button —
    reused for any campaign that has a cover image and a YouTube video. Clicking
    the button swaps the overlay for a playing embedded iframe in place (a
    click-to-load facade — the embed only loads once the visitor opts in). %>
<div class="video-embed relative h-64 overflow-hidden"
     <% if video_embed_url.present? %>data-controller="video-embed" data-video-embed-embed-url-value="<%= video_embed_url %>"<% end %>>
  <img src="<%= image_url %>" alt="<%= image_alt %>" class="absolute inset-0 h-full w-full object-cover">

  <% if video_embed_url.present? %>
    <button type="button" data-video-embed-target="overlay" data-action="video-embed#play"
            class="group absolute inset-0 flex items-center justify-center bg-black/20 transition hover:bg-black/30">
      <span class="flex items-center gap-3 rounded-full bg-white/90 px-5 py-3 shadow-lg transition group-hover:scale-105">
        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-orange-500 text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="-ms-0.5">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </span>
        <span class="text-sm font-semibold text-gray-800"></span>
      </span>
    </button>

    <div class="video-embed__player" data-action="keydown.esc@window->video-embed#close">
      <div class="video-embed__backdrop" data-action="click->video-embed#close"></div>
      <div class="video-embed__stage">
        <button type="button" data-action="video-embed#close" aria-label="סגירה"
                class="video-embed__close text-2xl leading-none text-white/80 hover:text-white">&times;</button>
        <div class="video-embed__frame" data-video-embed-target="frame"></div>
      </div>
    </div>
  <% end %>
</div>
